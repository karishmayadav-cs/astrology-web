# Backend Environment Variables Template
PORT=5000
NODE_ENV=development

# Allowed Frontend URL for CORS policy
# For local development: FRONTEND_URL=http://localhost:5173
# For single production domain (e.g. Vercel): FRONTEND_URL=https://your-frontend-app.vercel.app
# For multiple domains: FRONTEND_URL=http://localhost:5173,https://your-frontend-app.vercel.app
# For public API accepting all origins: FRONTEND_URL=*
FRONTEND_URL=http://localhost:5173

# Database & AI Service Keys
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>
GROQ_API_KEY=your_groq_api_key_here
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_BACKUP_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MAX_TOKENS=3000
GROQ_TEMPERATURE=0.8
GEMINI_API_KEY=your_gemini_api_key_here
